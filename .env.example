# SeraphimOS — LLM Provider API Keys
# Copy this file to .env and fill in your actual keys.
# .env is gitignored and will never be committed.

# Anthropic (Claude Haiku, Sonnet, Opus)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI (GPT-4o-mini, GPT-4o, GPT-4.5)
OPENAI_API_KEY=sk-your-key-here

# AWS Region (for Secrets Manager in production)
AWS_REGION=us-east-1

# Shaar Agent — Dashboard URL for browser observation
# Local dev: http://localhost:5173
# Production: your CloudFront/S3 dashboard URL
DASHBOARD_URL=http://localhost:5173

# Shaar Agent — Use Playwright for real browser observation (true/false)
# Set to false to use HTTP fetch fallback (for CI/environments without a browser)
SHAAR_USE_PLAYWRIGHT=true
