      ]
    },
    "build": {
      "commands": [
        "npm run typecheck",
        "npm run lint"
      ]
    }
  },
  "artifacts": {
    "base-directory": ".",
    "files": [
      "**/*"
    ],
    "exclude-paths": [
      "node_modules/**/*"
    ]
  }
}",
